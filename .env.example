PORT=8000
HOST=0.0.0.0
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/sijil
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=24h

ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-secure-password

# Meta WhatsApp Cloud API test environment
WHATSAPP_VERIFY_TOKEN=replace-with-a-long-random-verification-token
WHATSAPP_ACCESS_TOKEN=replace-with-meta-test-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-meta-test-phone-number-id
WHATSAPP_API_VERSION=v21.0
WHATSAPP_APP_SECRET=replace-with-meta-app-secret
